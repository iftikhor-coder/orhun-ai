# ============================================================
# ORHUN AI Backend — Environment Variables
# Bu faylni .env nomi bilan saqlang va to'ldiring
# .env'ni HECH QACHON git'ga commit qilmang!
# ============================================================

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# HuggingFace
HF_SPACE_URL=https://USERNAME-orhun-acestep.hf.space
HF_TOKEN=hf_xxxxx

# CORS — qaysi sayt'lardan so'rov qabul qilamiz
ALLOWED_ORIGINS=https://orhun-ai.vercel.app,http://localhost:3000

# Logging
LOG_LEVEL=INFO
